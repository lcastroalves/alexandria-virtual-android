<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    tools:context=".AdmTelaSolicPend">
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AdmTelaSolicPend">


    <ImageView
        android:id="@+id/logoUnifor"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center"
        android:src="@drawable/logoalexandriavirtual"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Solicitações Pendentes"
        android:textSize="24sp"
        android:textColor="#247AE8"
        android:fontFamily="@font/trocchi"
        app:layout_constraintTop_toBottomOf="@id/logoUnifor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />


    <LinearLayout
        android:id="@+id/layoutTabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitulo">

        <TextView
            android:id="@+id/tabPendentes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PENDENTES"
            android:textColor="#247AE8"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="24dp" />

        <TextView
            android:id="@+id/tabUsuarios"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="USUÁRIOS"
            android:clickable="true"
            android:focusable="true"
            android:textColor="#808080" />
    </LinearLayout>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSolicitacoes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:clipToPadding="false"
        android:paddingHorizontal="24dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/layoutTabs"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_solicitacao_pendente" />

</androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
