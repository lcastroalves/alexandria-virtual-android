<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/imgLivro"
        android:layout_width="90dp"
        android:layout_height="130dp"
        android:src="@drawable/livro1" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="8dp">

        <TextView
            android:id="@+id/txtTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Título do Livro"
            android:textStyle="bold"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtAutor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Autor"
            android:textColor="@android:color/black"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtAvaliacoes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐ 130 avaliações"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/btnAvaliacoes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ver avaliações"
            android:textStyle="bold"
            android:textColor="@android:color/holo_blue_dark"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/checkSelecionado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
</LinearLayout>
