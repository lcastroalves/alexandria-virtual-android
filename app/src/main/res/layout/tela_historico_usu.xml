<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TelaHistoricoUsu">

    <!-- Botão Voltar -->
    <ImageButton
        android:id="@+id/botaoVoltar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="60dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/descricaoBotaoVoltar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/icon" />

    <!-- Título -->
    <TextView
        android:id="@+id/historicoUsuario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Histórico"
        android:textColor="#2279E6"
        android:textSize="24sp"
        app:layout_constraintStart_toEndOf="@id/botaoVoltar"
        app:layout_constraintTop_toTopOf="@id/botaoVoltar"
        app:layout_constraintBottom_toBottomOf="@id/botaoVoltar"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Barra de Pesquisa -->
    <SearchView
        android:id="@+id/searchViewLivros"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="45dp"
        android:layout_marginTop="25dp"
        android:layout_marginEnd="46dp"
        android:iconifiedByDefault="false"
        android:queryHint="Buscar"
        app:layout_constraintTop_toBottomOf="@+id/historicoUsuario"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Card Livro 1 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardLivro1"
        android:layout_width="0dp"
        android:layout_height="148dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@+id/searchViewLivros"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/imgLivro1"
            android:layout_width="90dp"
            android:layout_height="130dp"
            android:src="@drawable/livro1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/txtTitulo1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ciência da Computação e Tecnologias Digitais"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@+id/imgLivro1"
            app:layout_constraintStart_toEndOf="@+id/imgLivro1"
            app:layout_constraintEnd_toStartOf="@+id/btnFav1"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/textView25"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐ 30 avaliações"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@+id/txtTitulo1"
            app:layout_constraintStart_toStartOf="@+id/txtTitulo1" />

        <TextView
            android:id="@+id/txtAutor1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ernane Rosa Martins"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@+id/textView25"
            app:layout_constraintStart_toStartOf="@+id/txtTitulo1" />

        <ImageView
            android:id="@+id/btnFav1"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/coracao_cheio"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="16dp" />


    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardLivro2"
        android:layout_width="0dp"
        android:layout_height="148dp"
        android:layout_marginTop="192dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/searchViewLivros">

        <ImageView
            android:id="@+id/imagemSoliPend"
            android:layout_width="90dp"
            android:layout_height="130dp"
            android:src="@drawable/livro2"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/nomeSoliPend"
            android:layout_width="268dp"
            android:layout_height="38dp"
            android:layout_marginStart="8dp"
            android:text="Ciência da Computação e Tecnologias Digitais"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/btnFav2"
            app:layout_constraintStart_toEndOf="@+id/imagemSoliPend"
            app:layout_constraintTop_toTopOf="@+id/imagemSoliPend" />

        <TextView
            android:id="@+id/textView26"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐ 12 avaliações"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@+id/nomeSoliPend"
            app:layout_constraintStart_toStartOf="@+id/nomeSoliPend"/>

        <TextView
            android:id="@+id/autorSoliPend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ernane Rosa Martins"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@+id/textView26"
            app:layout_constraintStart_toStartOf="@+id/nomeSoliPend" />

        <ImageView
            android:id="@+id/btnFav2"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/coracao_cheio"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
