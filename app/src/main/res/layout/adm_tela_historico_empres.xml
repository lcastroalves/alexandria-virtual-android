<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Logo -->
        <ImageView
            android:id="@+id/logoUnifor"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/logoalexandriavirtual"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Título -->
        <TextView
            android:id="@+id/tituloHistorico"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Histórico de empréstimos"
            android:textColor="#247AE8"
            android:textSize="22sp"
            android:fontFamily="@font/trocchi"
            app:layout_constraintTop_toBottomOf="@id/logoUnifor"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Tabs -->
        <LinearLayout
            android:id="@+id/tabs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tituloHistorico"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tabPendentes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PENDENTES"
                android:textColor="#6A6A6A"
                android:textSize="16sp"
                android:fontFamily="@font/montserrat_medium"
                android:paddingHorizontal="10dp" />

            <TextView
                android:id="@+id/tabUsuarios"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USUÁRIOS"
                android:textColor="#247AE8"
                android:textSize="16sp"
                android:fontFamily="@font/montserrat_medium"
                android:paddingHorizontal="10dp" />
        </LinearLayout>

        <!-- Lista de livros retirados (AJUSTADO PARA REMOVER layoutInfo) -->
        <TextView
            android:id="@+id/tituloLivrosRetirados"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#000"
            android:textSize="18sp"
            android:fontFamily="@font/montserrat_medium"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tabs"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerLivrosRetirados"
            android:layout_width="0dp"
            android:layout_height="260dp"
            android:overScrollMode="never"
            app:layout_constraintTop_toBottomOf="@id/tituloLivrosRetirados"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:listitem="@layout/item_livro_meus" />

        <!-- Situação -->
        <TextView
            android:id="@+id/tituloSituacao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Situação de Devoluções"
            android:textColor="#000"
            android:textSize="18sp"
            android:fontFamily="@font/montserrat_medium"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/recyclerLivrosRetirados"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/txtSituacao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-Em dia ✓"
            android:textColor="#00A651"
            android:textSize="16sp"
            android:fontFamily="@font/montserrat_medium"
            android:layout_marginBottom="32dp"
            app:layout_constraintTop_toBottomOf="@id/tituloSituacao"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
