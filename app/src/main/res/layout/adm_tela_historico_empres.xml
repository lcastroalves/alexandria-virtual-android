<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AdmTelaInicio">

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".AdmTelaHistoricoEmpres">


    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:background="@null"
        android:src="@drawable/seta_azul"
        android:contentDescription="Voltar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


    <ImageView
        android:id="@+id/logoUnifor"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:layout_gravity="center"
        android:src="@drawable/logoalexandriavirtual"
        android:contentDescription="Logo Alexandria"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <TextView
        android:id="@+id/tituloHistorico"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Histórico de empréstimos"
        android:textColor="#247AE8"
        android:textSize="22sp"
        android:fontFamily="@font/trocchi"
        app:layout_constraintTop_toBottomOf="@id/logoUnifor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <LinearLayout
        android:id="@+id/tabs"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tituloHistorico"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tabPendentes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PENDENTES"
            android:textColor="#6A6A6A"
            android:textSize="16sp"
            android:fontFamily="@font/montserrat_medium"
            android:paddingHorizontal="10dp" />

        <TextView
            android:id="@+id/tabUsuarios"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="USUÁRIOS"
            android:textColor="#247AE8"
            android:textSize="16sp"
            android:fontFamily="@font/montserrat_medium"
            android:paddingHorizontal="10dp" />
    </LinearLayout>


    <LinearLayout
        android:id="@+id/layoutInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/linear_layout_borda"
        android:padding="16dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tabs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txtResponsavel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nome do Responsável"
            android:textColor="#000"
            android:textSize="18sp"
            android:fontFamily="@font/montserrat_medium"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/txtUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Usuário: Felipe Barroso"
            android:textColor="#000"
            android:textSize="14sp"
            android:fontFamily="@font/montserrat"/>

        <TextView
            android:id="@+id/txtEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email: felipebvm@gmail.com"
            android:textColor="#000"
            android:textSize="14sp"
            android:fontFamily="@font/montserrat"/>
    </LinearLayout>


    <LinearLayout
        android:id="@+id/layoutLista"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/layoutInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lista de Livros Retirados"
            android:textColor="#000"
            android:textSize="18sp"
            android:fontFamily="@font/montserrat_medium"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerLivrosRetirados"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            tools:listitem="@layout/item_livro_meus"/>
    </LinearLayout>


    <LinearLayout
        android:id="@+id/layoutSituacao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutLista"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Situação de Devoluções"
            android:textColor="#000"
            android:textSize="18sp"
            android:fontFamily="@font/montserrat_medium"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/txtSituacao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-Em dia ✓"
            android:textColor="#00A651"
            android:textSize="16sp"
            android:fontFamily="@font/montserrat_medium"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
