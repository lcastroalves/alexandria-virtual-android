<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp"
    android:elevation="3dp">

    <ImageView
        android:id="@+id/imgLivro"
        android:layout_width="100dp"
        android:layout_height="140dp"
        android:layout_gravity="center"
        android:scaleType="fitXY"
        android:src="@drawable/livro2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtData"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="09 de Set"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginStart="20dp"
        app:layout_constraintStart_toEndOf="@+id/imgLivro"
        app:layout_constraintTop_toTopOf="@+id/imgLivro" />

    <TextView
        android:id="@+id/txtTituloLivro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Java como Programar"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="@+id/imgLivro"
        app:layout_constraintStart_toStartOf="@+id/imgLivro"
        app:layout_constraintTop_toBottomOf="@+id/imgLivro" />

    <TextView
        android:id="@+id/txtAutor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Autor: Paul Deitel"
        android:textColor="#000000"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="@+id/txtTituloLivro"
        app:layout_constraintStart_toStartOf="@+id/txtTituloLivro"
        app:layout_constraintTop_toBottomOf="@+id/txtTituloLivro" />

    <TextView
        android:id="@+id/txtUsuario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Usuário: Felipe Barroso"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="@+id/txtAutor"
        app:layout_constraintStart_toStartOf="@+id/txtAutor"
        app:layout_constraintTop_toBottomOf="@+id/txtAutor" />

    <TextView
        android:id="@+id/txtEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Email: felipebvm@gmail.com"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="@+id/txtUsuario"
        app:layout_constraintStart_toStartOf="@+id/txtUsuario"
        app:layout_constraintTop_toBottomOf="@+id/txtUsuario" />

    <TextView
        android:id="@+id/txtPrazo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Data limite: 12 de Set"
        android:textColor="#000000"
        android:textSize="14sp"
        android:layout_marginTop="6dp"
        app:layout_constraintEnd_toEndOf="@+id/txtEmail"
        app:layout_constraintStart_toStartOf="@+id/txtEmail"
        app:layout_constraintTop_toBottomOf="@+id/txtEmail" />

    <TextView
        android:id="@+id/txtLocal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Local: Balcão da Biblioteca"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="@+id/txtPrazo"
        app:layout_constraintStart_toStartOf="@+id/txtPrazo"
        app:layout_constraintTop_toBottomOf="@+id/txtPrazo" />

    <Button
        android:id="@+id/btnAutorizar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="#4CAF50"
        android:text="AUTORIZAR RETIRADA"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtLocal" />

    <Button
        android:id="@+id/btnRecusar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="#F44336"
        android:text="RECUSAR SOLICITAÇÃO"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnAutorizar" />
</androidx.constraintlayout.widget.ConstraintLayout>
