<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".TelaEmail">

    <!-- Botão Voltar -->
    <ImageButton
        android:id="@+id/botaoVoltar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="60dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/descricaoBotaoVoltar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/icon" />

    <!-- Título -->
    <TextView
        android:id="@+id/nomeEventosFuturos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="90dp"
        android:layout_marginTop="60dp"
        android:fontFamily="@font/trocchi"
        android:text="Editar evento"
        android:textColor="#247AE8"
        android:textSize="32sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Imagem do evento -->
    <ImageView
        android:id="@+id/imagemEventoEdit"
        android:layout_width="113dp"
        android:layout_height="122dp"
        android:contentDescription="@string/contDescLogo"
        app:layout_constraintTop_toBottomOf="@id/nomeEventosFuturos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/totoro" />

    <!-- Botão editar imagem -->
    <ImageButton
        android:id="@+id/editImagemEvento"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="-10dp"
        android:layout_marginEnd="50dp"
        android:background="@android:color/transparent"
        android:contentDescription="Editar imagem do evento"
        app:layout_constraintTop_toTopOf="@id/imagemEventoEdit"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/editprofile" />

    <!-- Área dos campos -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/imagemEventoEdit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Campo: Título -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textInputLayoutTitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="50dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/tituloEditarEvento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Título" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo: Data -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textInputLayoutData"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/textInputLayoutTitulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="50dp"
            android:layout_marginTop="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/dataEditarEvento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Data" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo: Horário -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textInputLayoutHorario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/textInputLayoutData"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="50dp"
            android:layout_marginTop="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/horarioEditarEvento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Horário" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo: Descrição -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textInputLayoutDescricao"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/textInputLayoutHorario"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="50dp"
            android:layout_marginTop="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/descricaoEditarEvento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Descrição" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo: Descrição breve -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textInputLayoutDescBreve"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/textInputLayoutDescricao"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="50dp"
            android:layout_marginTop="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/descricaoBreveEditarEvento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Descrição breve" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo: Local -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textInputLayoutLocal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/textInputLayoutDescBreve"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="50dp"
            android:layout_marginTop="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/localEditarEvento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Local" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Botão salvar -->
        <Button
            android:id="@+id/botaoSalvarEditarEvento"
            android:layout_width="140dp"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="#247AE8"
            android:fontFamily="@font/montserrat_medium"
            android:text="Salvar"
            android:textSize="18sp"
            app:cornerRadius="10dp"
            app:layout_constraintTop_toBottomOf="@id/textInputLayoutLocal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
