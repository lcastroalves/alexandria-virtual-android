<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    tools:context=".AdmTelaEditEvent">

    <!-- Botão Voltar -->
    <ImageButton
        android:id="@+id/botaoVoltar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="30dp"
        android:layout_marginTop="60dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/descricaoBotaoVoltar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/seta_azul" />

    <!-- Título -->
    <TextView
        android:id="@+id/tituloEditar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Editar evento"
        android:textColor="#247AE8"
        android:textSize="20sp"
        android:fontFamily="@font/trocchi"
        app:layout_constraintStart_toEndOf="@id/botaoVoltar"
        app:layout_constraintTop_toTopOf="@id/botaoVoltar"/>

    <!-- Botão editar imagem -->
    <ImageButton
        android:id="@+id/btnMudarImg"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:layout_marginEnd="120dp"
        android:layout_marginTop="10dp"
        android:background="@android:color/transparent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tituloEditar"
        app:srcCompat="@drawable/editing" />

    <!-- Imagem do Evento -->
    <ImageView
        android:id="@+id/imagemEventoEdit"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:scaleType="fitCenter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnMudarImg"
        android:src="@drawable/totoro"/>

    <!-- Scroll -->
    <ScrollView
        android:id="@+id/scrollCampos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/imagemEventoEdit"
        app:layout_constraintBottom_toTopOf="@+id/btnSalvar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp">

            <!-- Campo: Título -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputTitulo"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="Título"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusTopStart="5dp"
                app:boxCornerRadiusTopEnd="5dp"
                app:boxCornerRadiusBottomStart="5dp"
                app:boxCornerRadiusBottomEnd="5dp"
                app:boxStrokeColor="@color/borda_input"
                app:hintTextColor="#247AE8"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/tituloEvento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="13dp"
                    android:textSize="16sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Campo: Data -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputData"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:hint="Data"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusTopStart="5dp"
                app:boxCornerRadiusTopEnd="5dp"
                app:boxCornerRadiusBottomStart="5dp"
                app:boxCornerRadiusBottomEnd="5dp"
                app:boxStrokeColor="@color/borda_input"
                app:hintTextColor="#247AE8"
                app:layout_constraintTop_toBottomOf="@id/inputTitulo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/dataEvento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="13dp"
                    android:textSize="16sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Campo: Horário -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputHorario"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:hint="Horário"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusTopStart="5dp"
                app:boxCornerRadiusTopEnd="5dp"
                app:boxCornerRadiusBottomStart="5dp"
                app:boxCornerRadiusBottomEnd="5dp"
                app:boxStrokeColor="@color/borda_input"
                app:hintTextColor="#247AE8"
                app:layout_constraintTop_toBottomOf="@id/inputData"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/horarioEvento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="13dp"
                    android:textSize="16sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Campo: Descrição -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputDescricao"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:hint="Descrição"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusTopStart="5dp"
                app:boxCornerRadiusTopEnd="5dp"
                app:boxCornerRadiusBottomStart="5dp"
                app:boxCornerRadiusBottomEnd="5dp"
                app:boxStrokeColor="@color/borda_input"
                app:hintTextColor="#247AE8"
                app:layout_constraintTop_toBottomOf="@id/inputHorario"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/descricaoEvento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="13dp"
                    android:textSize="16sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Campo: Descrição curta -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputDescBreve"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:hint="Descrição breve"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusTopStart="5dp"
                app:boxCornerRadiusTopEnd="5dp"
                app:boxCornerRadiusBottomStart="5dp"
                app:boxCornerRadiusBottomEnd="5dp"
                app:boxStrokeColor="@color/borda_input"
                app:hintTextColor="#247AE8"
                app:layout_constraintTop_toBottomOf="@id/inputDescricao"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/descurtaEvento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="13dp"
                    android:textSize="16sp"/>
            </com.google.android.material.textfield.TextInputLayout>


            <!-- Campo: Local -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputLocalEvento"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:hint="Local"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusTopStart="5dp"
                app:boxCornerRadiusTopEnd="5dp"
                app:boxCornerRadiusBottomStart="5dp"
                app:boxCornerRadiusBottomEnd="5dp"
                app:boxStrokeColor="@color/borda_input"
                app:hintTextColor="#247AE8"
                app:layout_constraintTop_toBottomOf="@id/inputDescBreve"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/localEvento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="13dp"
                    android:textSize="16sp"/>
            </com.google.android.material.textfield.TextInputLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Botão salvar -->
    <Button
        android:id="@+id/btnSalvar"
        android:layout_width="205dp"
        android:layout_height="wrap_content"
        android:text="Salvar Alterações"
        android:textSize="18dp"
        android:backgroundTint="#2B76D7"
        android:fontFamily="@font/montserrat_medium"
        android:layout_marginBottom="20dp"
        app:cornerRadius="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
