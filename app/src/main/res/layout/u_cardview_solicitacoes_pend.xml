<?xml version="1.0" encoding="utf-8"?>
    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/constraintLayout3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="15dp"
        android:paddingHorizontal="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imagemSoliPend"
            android:layout_width="90dp"
            android:layout_height="139dp"
            android:layout_marginStart="4dp"
            android:contentDescription="Livro 2"
            android:src="@drawable/livro2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/nomeSoliPend"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:text="Java como Programar"
            android:textColor="#247AE8"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="10dp"
            app:layout_constraintStart_toEndOf="@+id/imagemSoliPend"
            app:layout_constraintTop_toTopOf="@+id/imagemSoliPend" />

        <TextView
            android:id="@+id/avaliacaoSoliPend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐ 105 avaliações"
            android:textSize="14sp"
            app:layout_constraintBottom_toTopOf="@+id/autorSoliPend"
            app:layout_constraintStart_toStartOf="@+id/nomeSoliPend"
            app:layout_constraintTop_toBottomOf="@+id/nomeSoliPend" />

        <TextView
            android:id="@+id/autorSoliPend"
            android:layout_width="150dp"
            android:maxLines="2"
            android:layout_height="wrap_content"
            android:text="Paul J. Deitel"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@+id/imagemSoliPend"
            app:layout_constraintStart_toStartOf="@+id/avaliacaoSoliPend" />

        <Button
            android:id="@+id/botaoSoliPend"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:backgroundTint="#247AE8"
            android:fontFamily="@font/montserrat_medium"
            android:text="OK"
            android:textSize="16dp"
            android:visibility="visible"
            app:cornerRadius="5dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/pendenteSoliPend"
        android:layout_width="80dp"
        android:layout_height="40dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/nomeSoliPend"
        app:srcCompat="@drawable/negado" />

</androidx.constraintlayout.widget.ConstraintLayout>
