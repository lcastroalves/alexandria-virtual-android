<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout3"
        android:layout_width="413dp"
        android:layout_height="148dp"
        android:layout_marginTop="30dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout3">

        <ImageView
            android:id="@+id/imagemSoliPend"
            android:layout_width="90dp"
            android:layout_height="139dp"
            android:layout_marginStart="4dp"
            android:contentDescription="Livro 2"
            android:src="@drawable/livro2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.333" />

        <TextView
            android:id="@+id/nomeSoliPend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="-140dp"
            android:layout_marginTop="10dp"
            android:text="Java como Programar"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/imagemSoliPend"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/avaliacaoSoliPend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="-190dp"
            android:layout_marginTop="25dp"
            android:text="⭐ 105 avaliações"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/imagemSoliPend"
            app:layout_constraintTop_toBottomOf="@+id/nomeSoliPend" />

        <TextView
            android:id="@+id/autorSoliPend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="-200dp"
            android:layout_marginTop="25dp"
            android:text="Paul J. Deitel"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/imagemSoliPend"
            app:layout_constraintTop_toBottomOf="@+id/avaliacaoSoliPend" />

        <TextView
            android:id="@+id/pendenteSoliPend"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="75dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:fontFamily="@font/montserrat"
            android:text="Negado!"
            android:textColor="#F44336"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/nomeSoliPend"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/botaoSoliPend"
            android:layout_width="88dp"
            android:layout_height="56dp"
            android:layout_marginTop="76dp"
            android:layout_marginEnd="-200dp"
            android:backgroundTint="#247AE8"
            android:fontFamily="@font/montserrat_medium"
            android:text="OK"
            android:textSize="25dp"
            app:cornerRadius="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.512"
            app:layout_constraintStart_toEndOf="@+id/imagemSoliPend"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>