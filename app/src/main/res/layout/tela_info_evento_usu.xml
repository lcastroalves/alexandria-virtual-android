<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".TelaEmail">

    <!-- Botão voltar -->
    <ImageButton
        android:id="@+id/botaoVoltar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="60dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/descricaoBotaoVoltar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/seta_azul" />

    <!-- Botão fixo inferior -->
    <Button
        android:id="@+id/botaoNotificar"
        android:layout_width="200dp"
        android:layout_height="55dp"
        android:layout_marginBottom="50dp"
        android:backgroundTint="#247AE8"
        android:fontFamily="@font/montserrat"
        android:text="Me notificar"
        android:textSize="20sp"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ScrollView ocupa apenas o espaço entre o topo e o botão -->
    <ScrollView
        android:id="@+id/scrollPrincipal"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/botaoVoltar"
        app:layout_constraintBottom_toTopOf="@id/botaoNotificar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constraintInterna"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Imagem -->
            <ImageView
                android:id="@+id/imagemInfoAtividade"
                android:layout_width="120dp"
                android:layout_height="160dp"
                android:layout_marginTop="20dp"
                android:scaleType="fitXY"
                android:contentDescription="@string/contDescLogo"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:srcCompat="@drawable/totoro" />

            <!-- Nome -->
            <TextView
                android:id="@+id/nomeInfoAtividade"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/trocchi"
                android:text="O meu vizinho Totoro"
                android:gravity="center"
                android:textColor="#247AE8"
                android:textSize="28sp"
                app:layout_constraintTop_toBottomOf="@id/imagemInfoAtividade"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Horário -->
            <TextView
                android:id="@+id/horarioInfoAtividade"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="16:00 - 17:30"
                android:textColor="#247AE8"
                android:textSize="18sp"
                app:layout_constraintTop_toBottomOf="@id/nomeInfoAtividade"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Fundo da descrição -->
            <ImageView
                android:id="@+id/fundoDescricao"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                android:adjustViewBounds="true"
                app:layout_constraintTop_toBottomOf="@id/horarioInfoAtividade"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:srcCompat="@drawable/retangulo_azul" />

            <!-- Descrição -->
            <TextView
                android:id="@+id/descricaoInfoAtividade"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="30dp"
                android:text="Descrição:"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                app:layout_constraintTop_toTopOf="@id/fundoDescricao"
                app:layout_constraintStart_toStartOf="@id/fundoDescricao"
                app:layout_constraintEnd_toEndOf="@id/fundoDescricao" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
