<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TelaMeusLivrosUsu">

    <!-- ScrollView para permitir rolagem vertical -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <!-- Todo o conteúdo dentro do ScrollView -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <!-- Topo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/btnback"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="start"
                    android:layout_marginTop="40dp"
                    android:layout_marginStart="20dp"
                    android:src="@drawable/seta_azul"
                    android:background="@android:color/transparent"/>

                <ImageView
                    android:id="@+id/logoUnifor"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="10dp"
                    android:src="@drawable/logoalexandriavirtual"
                    android:contentDescription="Logo Alexandria"/>
            </LinearLayout>

            <!-- Título -->
            <TextView
                android:id="@+id/tituloAlexandria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/trocchi"
                android:text="Meus Livros"
                android:textColor="#247AE8"
                android:textSize="26sp" />

            <!-- Classificação -->
            <TextView
                android:id="@+id/txtClassificar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Classificar por:"
                android:textSize="18sp"
                android:textColor="#000000"
                android:layout_marginTop="15dp"
                android:layout_marginStart="20dp"
                android:fontFamily="@font/montserrat_medium" />

            <!-- Filtros -->
            <LinearLayout
                android:id="@+id/layoutFiltros"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp"
                android:layout_marginHorizontal="20dp"
                android:background="@drawable/linear_layout_borda">

                <TextView
                    android:id="@+id/filtroAlugados"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alugados Recentemente"
                    android:textColor="#247AE8"
                    android:fontFamily="@font/montserrat_medium"
                    android:textSize="16sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:padding="4dp"
                    android:layout_marginBottom="5dp" />

                <TextView
                    android:id="@+id/filtroLidos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lidos Recentemente"
                    android:textColor="#247AE8"
                    android:fontFamily="@font/montserrat_medium"
                    android:textSize="16sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:padding="4dp"
                    android:layout_marginBottom="5dp" />

                <TextView
                    android:id="@+id/filtroAZ"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alfabética A-Z"
                    android:textColor="#247AE8"
                    android:fontFamily="@font/montserrat_medium"
                    android:textSize="16sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:padding="4dp"/>
            </LinearLayout>

            <!-- RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerLivros"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="10dp"
                android:clipToPadding="false"
                android:overScrollMode="never"
                tools:listitem="@layout/item_livro_meus" />

            <!-- Progresso -->
            <LinearLayout
                android:id="@+id/layoutProgresso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="15dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    app:srcCompat="@drawable/open_bookk"
                    app:tint="#000000"
                    android:contentDescription="Progresso" />

                <TextView
                    android:id="@+id/txtProgresso"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:fontFamily="@font/montserrat_medium"
                    android:text="3/12"
                    android:textColor="#000000"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Botão Avaliar -->
            <Button
                android:id="@+id/btnAvaliarLivros"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="40dp"
                android:backgroundTint="#2B76D7"
                android:fontFamily="@font/montserrat_medium"
                android:text="AVALIAR LIVROS"
                android:textSize="20sp"
                android:paddingHorizontal="30dp"
                android:paddingVertical="15dp"
                app:cornerRadius="10dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
