<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AdmTelaEventos">

    <SearchView
        android:id="@+id/searchViewLivros"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="-80dp"
        android:layout_weight="1"
        android:iconifiedByDefault="false"
        android:queryHint="Buscar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/botaoAdEvento" />

    <Button
        android:id="@+id/botaoAdEvento"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:layout_marginEnd="30dp"
        android:layout_marginTop="120dp"
        android:backgroundTint="#247AE8"
        android:fontFamily="@font/montserrat"
        android:scaleX="1"
        android:text="Adicionar evento"
        android:textAlignment="center"
        android:textSize="16sp"
        app:cornerRadius="10sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/solicitacoesPendentes2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/trocchi"
        android:text="Eventos"
        android:textColor="#2279E6"
        android:textSize="20sp"
        android:layout_marginStart="10dp"
        app:layout_constraintBottom_toBottomOf="@+id/botaoVoltar2"
        app:layout_constraintStart_toEndOf="@+id/botaoVoltar2"
        app:layout_constraintTop_toTopOf="@+id/botaoVoltar2" />

    <ImageButton
        android:id="@+id/botaoVoltar2"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="60dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/descricaoBotaoVoltar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/seta_azul" />

    <ImageButton
        android:id="@+id/botaoExcluirEventos"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginTop="172dp"
        android:layout_marginEnd="16dp"
        android:scaleType="fitCenter"
        android:background="@android:color/transparent"
        android:contentDescription="Excluir evento"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/trash_vector" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyListaEventoAdm"
        android:layout_width="409dp"
        android:layout_height="504dp"
        android:layout_marginStart="1dp"
        android:layout_marginEnd="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/searchViewLivros" />

</androidx.constraintlayout.widget.ConstraintLayout>