<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <!-- INFORMAÇÕES DO RESPONSÁVEL -->
    <TextView
        android:id="@+id/txtNomeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nome do Responsável"
        android:textStyle="bold"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/txtNomeResponsavel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@+id/txtNomeLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Usuário: Felipe Barroso" />

    <TextView
        android:id="@+id/txtEmailResponsavel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@+id/txtNomeResponsavel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Email: felipebvm@gmail.com" />


    <!-- TÍTULO LISTA DE LIVROS -->
    <TextView
        android:id="@+id/txtListaLivrosLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Lista de Livros Retirados"
        android:textStyle="bold"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@+id/txtEmailResponsavel"
        app:layout_constraintStart_toStartOf="parent" />


    <!-- CAPA DO LIVRO -->
    <ImageView
        android:id="@+id/imgCapa"
        android:layout_width="90dp"
        android:layout_height="130dp"
        android:layout_marginTop="16dp"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        app:layout_constraintTop_toBottomOf="@+id/txtListaLivrosLabel"
        app:layout_constraintStart_toStartOf="parent"
        tools:src="@tools:sample/avatars" />


    <!-- DETALHES DO LIVRO -->
    <LinearLayout
        android:id="@+id/layoutDetalhesLivro"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        app:layout_constraintTop_toTopOf="@+id/imgCapa"
        app:layout_constraintStart_toEndOf="@+id/imgCapa"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txtTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="16sp"
            tools:text="Ciência da Computação" />

        <TextView
            android:id="@+id/txtAutor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            tools:text="Autor: Ednaldo Rosa" />

        <TextView
            android:id="@+id/txtDataRetirada"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            tools:text="09 de Set" />
    </LinearLayout>


    <!-- SITUAÇÃO DA DEVOLUÇÃO -->
    <TextView
        android:id="@+id/txtSituacaoLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Situação de Devoluções"
        android:textStyle="bold"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@+id/imgCapa"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/txtSituacaoDevolucao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textStyle="bold"
        android:textColor="#4CAF50"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@+id/txtSituacaoLabel"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="-Em dia ✔️"/>
</androidx.constraintlayout.widget.ConstraintLayout>
