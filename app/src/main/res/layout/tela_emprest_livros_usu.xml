<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TelaEmprestLivrosUsu">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">


        <ImageButton
            android:id="@+id/btnback"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start"
            android:layout_marginTop="40dp"
            android:background="@android:color/transparent"
            android:clipToOutline="true"
            android:scaleType="centerCrop"
            app:srcCompat="@drawable/seta_azul" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <SearchView
                android:id="@+id/searchViewLivros"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:queryHint="Buscar"
                android:iconifiedByDefault="false" />

        </LinearLayout>


        <TextView
            android:id="@+id/textTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Empréstimo de Livros"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/holo_blue_dark"
            android:gravity="center"
            android:layout_marginVertical="16dp" />

        <!-- Filtros -->
        <LinearLayout
            android:id="@+id/linearLayoutFiltros"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:background="#F4F4F4"
            android:elevation="2dp"
            android:layout_marginBottom="16dp"
            android:layout_marginHorizontal="8dp"
            android:clipToOutline="true">

            <TextView
                android:id="@+id/textFiltros"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filtros e Categorias"
                android:textColor="@android:color/black"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerAutor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp" />

            <Spinner
                android:id="@+id/spinnerGenero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp" />

            <Spinner
                android:id="@+id/spinnerMaisPopulares"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp" />

            <Spinner
                android:id="@+id/spinnerLancamento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp" />
        </LinearLayout>

        <!-- Livro 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginVertical="8dp">

            <ImageView
                android:id="@+id/imgLivro1"
                android:layout_width="90dp"
                android:layout_height="130dp"
                android:src="@drawable/livro1"
                android:contentDescription="Livro 1" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/txtTitulo1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ciência da Computação e Tecnologias Digitais"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/txtAutor1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ernane Rosa Martins"
                    android:textColor="@android:color/black"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 130 avaliações"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/btnAvaliacoes1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ver avaliações"
                    android:textStyle="bold"
                    android:textColor="@android:color/holo_blue_dark"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <CheckBox
                android:id="@+id/checkLivro1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical" />
        </LinearLayout>

        <!-- Livro 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginVertical="8dp">

            <ImageView
                android:id="@+id/imgLivro2"
                android:layout_width="90dp"
                android:layout_height="130dp"
                android:src="@drawable/livro2"
                android:contentDescription="Livro 2" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/txtTitulo2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Java como Programar"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/txtAutor2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paul J. Deitel"
                    android:textColor="@android:color/black"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 105 avaliações"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/btnAvaliacoes2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ver avaliações"
                    android:textStyle="bold"
                    android:textColor="@android:color/holo_blue_dark"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <CheckBox
                android:id="@+id/checkLivro2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical" />
        </LinearLayout>

        <!-- Botão confirmar -->
        <Button
            android:id="@+id/btnConfirmar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONFIRMAR"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>
