<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="0dp">

        <TextView
            android:id="@+id/nomeEventoLista"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/montserrat"
            android:text="Nome"
            android:textColor="#247AE8"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.053"
            app:layout_constraintStart_toEndOf="@+id/imagemEventoLista"
            app:layout_constraintTop_toTopOf="@+id/imagemEventoLista" />

        <ImageView
            android:id="@+id/imagemEventoLista"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/livro"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/dataEventoLista"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Tipo"
            android:textColor="#247AE8"
            android:textSize="10sp"
            app:layout_constraintStart_toEndOf="@+id/nomeEventoLista"
            app:layout_constraintTop_toTopOf="@+id/nomeEventoLista" />

        <TextView
            android:id="@+id/descricaoEventoLista"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:fontFamily="@font/montserrat"
            android:text="Mensagem"
            android:textColor="#247AE8"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/imagemEventoLista"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.055"
            app:layout_constraintStart_toEndOf="@+id/imagemEventoLista"
            app:layout_constraintTop_toBottomOf="@+id/nomeEventoLista" />

        <TextView
            android:id="@+id/data"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="130dp"
            android:text="Data"
            android:textColor="#247AE8"
            android:textSize="10sp"
            app:layout_constraintStart_toEndOf="@+id/nomeEventoLista"
            app:layout_constraintTop_toTopOf="@+id/nomeEventoLista" />

        <ImageButton
            android:id="@+id/btnExcluir"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="20dp"
            android:background="@android:color/transparent"
            android:contentDescription="Botão excluir"

            android:src="@drawable/x_1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/data"
            app:layout_constraintTop_toTopOf="@+id/data">

        </ImageButton>


    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.cardview.widget.CardView>