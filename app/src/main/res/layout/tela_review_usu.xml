<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TelaReviewUsu">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="215dp"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnback"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="start"
                android:layout_marginTop="40dp"
                android:layout_marginStart="20dp"
                android:src="@drawable/seta_azul"
                android:background="@android:color/transparent"/>

            <ImageView
                android:id="@+id/logoUnifor"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:layout_marginBottom="140dp"
                android:background="@drawable/logoalexandriavirtual"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:src="@drawable/logoalexandriavirtual"
                app:layout_constraintBottom_toTopOf="@+id/linearLayout"
                tools:layout_editor_absoluteX="155dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tituloAlexandria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/trocchi"
            android:text="Reviews"
            android:textColor="#247AE8"
            android:textSize="32dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerLivros"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:paddingHorizontal="32dp"
            android:overScrollMode="never"
            android:scrollbars="none"
            tools:listitem="@layout/item_livro_review" />

        <TextView
            android:id="@+id/txtSuaAvaliacao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="Sua Avaliação"
            android:textColor="#000000"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/layoutEstrelas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="100dp"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:id="@+id/estrela1"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/star_black"
                android:clickable="true"
                android:focusable="true"
                android:layout_margin="4dp" />
            <ImageView
                android:id="@+id/estrela2"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/star_black"
                android:clickable="true"
                android:focusable="true"
                android:layout_margin="4dp" />

            <ImageView
                android:id="@+id/estrela3"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/star_black"
                android:clickable="true"
                android:focusable="true"
                android:layout_margin="4dp" />

            <ImageView
                android:id="@+id/estrela4"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/star_black"
                android:clickable="true"
                android:focusable="true"
                android:layout_margin="4dp" />

            <ImageView
                android:id="@+id/estrela5"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/star_black"
                android:clickable="true"
                android:focusable="true"
                android:layout_margin="4dp" />
        </LinearLayout>
        <EditText
            android:id="@+id/editAvaliacao"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="Escreva aqui sua avaliação"
            android:background="@drawable/edittext_background"
            android:gravity="top|start"
            android:padding="12dp"
            android:layout_marginTop="12dp"
            android:inputType="textMultiLine" />
        <Button
            android:id="@+id/btnEnviar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ENVIAR AVALIAÇÃO"
            android:textAllCaps="false"
            android:backgroundTint="#247AE8"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/montserrat_medium" />
        <TextView
            android:id="@+id/txtAvaliacoes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Avaliações"
            android:textColor="#000000"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/txtNotaGeral"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4,3 ★★★★★"
            android:textSize="24sp"
            android:textColor="#000000"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>